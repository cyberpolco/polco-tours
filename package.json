{
  "name": "polco-tours",
  "version": "0.1.0",
  "private": true,
  "description": "POLCO TOURS \u2014 Tourism Operating System for Namibia & the DRC. Phase 0 foundation.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:rls": "node scripts/apply-rls.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:push && npm run db:rls && npm run db:seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "better-auth": "1.6.23",
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "2.1.8",
    "@eslint/eslintrc": "3.2.0",
    "@types/node": "20.17.12",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.1",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
