// POLCO TOURS — Prisma schema (Phase 0 foundation)
// Implements the Vol. 6 identity/tenancy/finance/system core plus a single
// tenant-scoped table (tour_packages) used to prove Row-Level Security.
// Full ERD grows here phase by phase; every structural change is recorded in
// docs/decisions (DR-007, living-document mandate).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Neon -pooler) at runtime
  directUrl = env("DIRECT_URL") // direct connection for migrations
}

// ----------------------------------------------------------------- enums
enum Role {
  SUPERADMIN
  PLATFORM_ADMIN
  TOUR_OPERATOR
  TOUR_GUIDE
  DRIVER
  VEHICLE_OWNER
  VISA_FACILITATOR
  TOURIST
}

enum OrgStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Currency {
  USD
  EUR
  NAD
  CDF
}

enum DepartureStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

// v2 (replaces HELD/CONFIRMED/CANCELLED/EXPIRED/QUOTE_REQUESTED). A hold is
// now AWAITING_DEPOSIT + holdExpiresAt (was HELD); an expired hold lazily
// sweeps straight to CANCELLED -- there is no dedicated EXPIRED value here,
// so the expired-vs-manually-cancelled distinction survives only in the
// audit log. DRAFT exists for spec completeness; no current flow produces a
// row that stays there (both booking origins set a real starting status
// immediately on creation).
enum BookingStatus {
  DRAFT
  AWAITING_QUOTATION
  QUOTATION_SENT
  AWAITING_DEPOSIT
  DEPOSIT_PAID
  FULLY_PAID
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum BookingOrigin {
  PREDEFINED_PACKAGE
  TAILOR_MADE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentKind {
  DEPOSIT
  BALANCE
  FULL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum Locale {
  EN
  FR
}

// ICAO 9303 passport MRZ sex convention (matches what a passport encodes).
enum Sex {
  M
  F
  X
}

enum AddonCode {
  PHOTOGRAPHY
  VIDEOGRAPHY
  TRANSLATOR
  VISA_ASSISTANCE
}

// Powers the public "tailor your trip" quiz's interest-matching (DR-016).
enum PackageTag {
  WILDLIFE
  ADVENTURE
  RELAXATION
  FAMILY
  CULTURE
  LUXURY
  BUDGET
}

// Fleet + compliance (DR-017, Phase 2 Increment 1).
enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum DriverStatus {
  ACTIVE
  SUSPENDED
}

// Guides Module (DR-030) -- folded into the fleet module per explicit user
// choice, rather than a standalone module, to reuse its existing
// compliance-document/anti-BOLA plumbing directly.
enum GuideStatus {
  ACTIVE
  SUSPENDED
}

// ------------------------------------------------------------- identity
model Organization {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  countries     String[] // ISO-3166 alpha-2, e.g. ["NA","CD"]
  status        OrgStatus @default(PENDING)
  isPrimary     Boolean   @default(false)
  // "The Tour Operator"'s own agency-wide score (DR-037), live-recomputed
  // from Review.overallRating on every submission -- written directly by
  // ratingsRepository, since no module otherwise owns Organization (same
  // "shared, no owning module" precedent as TaxRate pre-DR-034).
  averageRating Float?
  ratingCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  members               Membership[]
  packages              TourPackage[]
  departures            Departure[]
  bookings              Booking[]
  invoices              Invoice[]
  payments              Payment[]
  travelers             Traveler[]
  documents             Document[]
  addonServices         AddonService[]
  bookingAddons         BookingAddon[]
  vehicles              Vehicle[]
  driverProfiles        DriverProfile[]
  guideProfiles         GuideProfile[]
  assignments           Assignment[]
  visaApplications      VisaApplication[]
  maintenanceRecords    MaintenanceRecord[]
  starlinkKits          StarlinkKit[]
  itineraries           Itinerary[]
  itineraryDays         ItineraryDay[]
  hotels                Hotel[]
  restaurants           Restaurant[]
  itineraryHotels       ItineraryHotel[]
  itineraryRestaurants  ItineraryRestaurant[]
  ratingCodes           RatingCode[]
  reviews               Review[]
  reviewSubjectRatings  ReviewSubjectRating[]
  packageCostBreakdowns PackageCostBreakdown[]
  packageCostLineItems  PackageCostLineItem[]
  hotelRatings          HotelRating[]
  restaurantRatings     RestaurantRating[]
  packageItineraryDays  PackageItineraryDay[]

  @@map("organizations")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  name               String?
  role               Role      @default(TOURIST)
  emailVerified      Boolean   @default(false)
  image              String? // better-auth: avatar URL
  phone              String? // E.164 -- WhatsApp/SMS addressing (DR-013)
  preferredLocale    Locale    @default(EN)
  isAnonymous        Boolean?  @default(false) // better-auth `anonymous` plugin (DR-016 guest checkout)
  organizationId     String?   @db.Uuid
  mustChangePassword Boolean   @default(false) // set true for admin-created accounts with a generated temp password (DR-026)
  // Set via a databaseHooks.session.create.after hook in src/lib/auth.ts
  // (a plain prisma.user.update, not part of better-auth's own managed
  // payload -- no additionalFields registration needed) -- the moment a
  // new Session row is created, i.e. an actual sign-in, not just any
  // authenticated request. Powers the "Last login" column on
  // /staff/admin/users.
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  memberships          Membership[]
  sessions             Session[]
  accounts             Account[]
  bookings             Booking[]
  ownedVehicles        Vehicle[]
  driverProfile        DriverProfile?
  guideProfile         GuideProfile?
  guideAssignments     Assignment[]
  reviewSubjectRatings ReviewSubjectRating[]
  hotelRatings         HotelRating[]
  restaurantRatings    RestaurantRating[]

  @@index([organizationId])
  @@map("users")
}

// A user's role within a specific organization (multi-tenant membership).
// DR-026: real multi-role source of truth for staff accounts created via the
// admin user-management surface -- one row per (user, org, role) a user
// holds simultaneously. User.role stays a single "primary" role used
// unchanged by tourist/guest self-signup, which never gets a Membership row.
model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  organizationId String   @db.Uuid
  role           Role
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId])
  @@map("organization_members")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// --------------------------------------------------------------- finance
// Per-country, effective-dated tax (DR-006 / BR-01). Rate in basis points.
model TaxRate {
  id        String    @id @default(uuid()) @db.Uuid
  country   String // ISO-3166 alpha-2
  taxType   String    @default("VAT")
  rateBp    Int // 1600 = 16.00%
  validFrom DateTime  @default(now())
  validTo   DateTime?

  @@index([country, taxType, validFrom])
  @@map("tax_rates")
}

// Settings module (DR-042): the platform's own commission on every online
// payment processed ("the cost to maintain the platform") -- a single
// global rate, not per-country (unlike TaxRate). Platform-wide reference
// data, no organizationId/RLS, same precedent as TaxRate. Informational
// only: Invoice.platformFeeMinor is a computed split of the existing total,
// never added on top of what the customer pays (see Invoice below).
model PlatformRate {
  id        String    @id @default(uuid()) @db.Uuid
  rateBp    Int // 500 = 5.00%
  validFrom DateTime  @default(now())
  validTo   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([validFrom])
  @@map("platform_rates")
}

// Content module (DR-043): staff-editable guest-site content, replacing what
// used to be hardcoded JSX/TS literals in src/app/(guest)/{about,faq}. No
// organizationId/RLS -- same precedent as TaxRate/CountryRegulation, and
// consistent with the guest site's existing single-primary-org convention
// (getPrimaryOrgId() already resolves one global org for every guest page,
// so there's no per-tenant guest-content story to preserve). Write is
// SUPERADMIN-only (content.write, enforced in content/service.ts).
model SiteContent {
  id              String   @id @default(uuid()) @db.Uuid
  key             String   @unique // e.g. "about"
  title           String
  body            String   @db.Text
  updatedAt       DateTime @updatedAt
  updatedByUserId String?  @db.Uuid

  @@map("site_content")
}

// Same precedent as SiteContent, but repeated rows (one per Q&A) instead of
// a single-row-per-key blob.
model FaqEntry {
  id        String   @id @default(uuid()) @db.Uuid
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("faq_entries")
}

// Platform-wide reference data, one row per country (Immigration Module,
// DR-034) -- NOT tenant-scoped (no organizationId), same "objective fact
// about a country, not operator-owned data" reasoning as TaxRate above; no
// RLS policy either, same precedent. Deliberately not effective-dated like
// TaxRate -- a single current snapshot per country, edited in place; a
// historical trail of who changed what lives in audit_logs, not here.
// Write access is SUPERADMIN-only (country_regulation.write in rbac.ts,
// enforced in immigration/service.ts -- PLATFORM_ADMIN is deliberately
// excluded, the first real behavioral gap between the two admin roles in
// this app). Read access goes to whoever processes visas (rbac.ts).
model CountryRegulation {
  id      String @id @default(uuid()) @db.Uuid
  country String @unique @db.VarChar(2) // ISO-3166 alpha-2, matches TaxRate.country/Traveler.nationality

  visaRequirements   String @db.Text // who needs what (e-visa/on-arrival/exempt) -- free text since nationality-by-nationality rules shift too often for a relational model here
  requiredDocuments  String @db.Text // free text checklist (passport validity window, photos, invitation letter, etc.)
  processingTimeDays Int? // typical turnaround; nullable, not every country publishes one figure

  entryConditions     String    @db.Text // yellow fever proof, health forms, quarantine rules, etc.
  immigrationFeeMinor Int? // integer minor units (BR-02), paired with feeCurrency -- never a bare number
  feeCurrency         Currency? // paired with immigrationFeeMinor -- both null together when no flat fee is published

  embassyName    String?
  embassyAddress String?
  embassyPhone   String?
  embassyEmail   String?

  healthRequirements  String  @db.Text // vaccination/malaria prophylaxis guidance
  travelAdvisories    String? @db.Text // current advisory summary -- nullable, not every country has an active one
  specialRestrictions String? @db.Text // e.g. DRC's BR-07 security-zone posture -- nullable, most countries have none

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("country_regulations")
}

// Platform-wide, DB-backed permission grants (User Management, DR-035) --
// one row per (role, permission) currently granted. Global, no
// organizationId/RLS, same precedent as TaxRate/CountryRegulation: role
// definitions are a platform concept, not per-tenant data.
//
// SUPERADMIN deliberately has NO rows here and never will -- it stays a
// hardcoded, unconditional wildcard in src/lib/rbac.ts, a permanent
// "master key" that can never be edited or locked out via this table.
// Every other role (including PLATFORM_ADMIN, per explicit user choice --
// the first role since DR-034 to lose its permanent wildcard) is fully
// editable through this table; `authService.resolveSession` reads it once
// per request to build AuthContext.permissions. Seeded from the static
// matrix that existed before this table (see prisma/seed.ts).
model RolePermission {
  id         String   @id @default(uuid()) @db.Uuid
  role       Role
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@map("role_permissions")
}

// ---------------------------------------------------------------- system
// Append-only. INSERT/UPDATE/DELETE grants are locked down in rls.sql.
model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  actorUserId    String?  @db.Uuid
  // Plain string, not the Role enum -- this table is meant to outlive its
  // actors (same reasoning as actorUserId staying a bare, non-FK uuid after
  // DR-026's user deletions), and DR-032 confirmed why the enum shape
  // breaks that: 22 historical rows record `IMMIGRATION_OFFICER` actions
  // from before that role was removed entirely, which a real enum could
  // no longer represent once the value stopped existing.
  actorRole      String?
  action         String
  resourceType   String
  resourceId     String?
  organizationId String?  @db.Uuid
  ip             String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ------------------------------------------------------------ catalog (Vol. 1)
// Tenant-scoped. RLS policies in rls.sql enforce that a request only sees rows
// for the organization in the session GUC `app.org_id`.
model TourPackage {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @db.Uuid
  // Business-facing reference, e.g. PKG-00034, from a plain Postgres sequence
  // (package_reference_seq -- not representable in Prisma's schema DSL, see
  // src/modules/catalog/repository.ts), same coexists-alongside-the-id
  // pattern as Booking.bookingReference (DR-027).
  packageReference String        @unique
  title            String
  description      String
  country          String // ISO-3166 alpha-2; matches TaxRate.country for invoicing
  // Per-seat unit price, integer minor units (BR-02). Nullable since DR-039:
  // a brand-new package starts unpriced until the finance module's cost
  // breakdown computes it (or an admin override sets it) -- isBookable
  // treats null as not-bookable. Existing packages keep their pre-DR-039
  // value (grandfathered, no cost breakdown required retroactively).
  priceMinor       Int?
  currency         Currency
  durationDays     Int?
  tags             PackageTag[] // interest-matching for the public quiz (DR-016)
  status           PackageStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  // Soft delete (DR-028) -- already existed, scaffolded but unused until now;
  // reads across this module already filter deletedAt: null.
  deletedAt        DateTime?

  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departures          Departure[]
  costBreakdown       PackageCostBreakdown?
  itineraryTemplateDays PackageItineraryDay[]

  @@index([organizationId])
  @@map("tour_packages")
}

// A reusable day-by-day itinerary template for a package -- copied onto a
// fresh Itinerary's real, dated ItineraryDay rows the moment one is created
// for a booking against this package (itineraryService.createItinerary),
// so staff review/adjust an already-populated plan instead of building one
// from scratch every time. dayNumber is relative to the trip's start (day
// 1, day 2, ...), not a real calendar date -- the real date only exists
// once a specific booking's Departure.startDate is known. Deliberately
// mirrors ItineraryDay's shape (itinerary module) rather than being shared
// with it -- this is catalog-owned reference/template data, that one is a
// live per-booking record; duplicating the shape is simpler than the two
// modules depending on each other for one shared type.
model PackageItineraryDay {
  id                     String   @id @default(uuid()) @db.Uuid
  organizationId         String   @db.Uuid
  tourPackageId          String   @db.Uuid
  dayNumber              Int
  departureTime          String?
  arrivalTime            String?
  pickupLocation         String?
  dropoffLocation        String?
  plannedSites           String?  @db.Text
  activities             String?  @db.Text
  estimatedTravelMinutes Int?
  notes                  String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tourPackage  TourPackage  @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)

  @@unique([tourPackageId, dayNumber])
  @@index([organizationId])
  @@index([tourPackageId])
  @@map("package_itinerary_days")
}

// A scheduled instance of a TourPackage. Capacity lives here (not on the
// package) because two departures of the same package can run different
// group/vehicle sizes.
//
// DR-028: tourPackageId is now nullable -- a "bespoke" departure (converted
// from an approved TAILOR_MADE Booking, see bookingService.convertToItinerary)
// has no TourPackage at all. Its country/price/currency are snapshotted
// directly onto customCountry/priceOverrideMinor/currency instead (catalog
// module cannot depend on the booking module -- see catalogService
// .createBespokeDeparture -- so these carry what a package join would
// otherwise have supplied). A bespoke departure is never publicly listed and
// exists solely so the existing Assignment machinery can attach to it.
model Departure {
  id                 String          @id @default(uuid()) @db.Uuid
  organizationId     String          @db.Uuid
  tourPackageId      String?         @db.Uuid
  startDate          DateTime
  endDate            DateTime?
  capacity           Int
  priceOverrideMinor Int? // null = inherit TourPackage.priceMinor/currency; for a bespoke departure, this IS the price (no package to inherit from)
  currency           Currency? // bespoke departures only -- a package-backed departure inherits TourPackage.currency
  customCountry      String?         @db.VarChar(2) // bespoke departures only -- ISO-3166 alpha-2, snapshotted from the originating Booking
  // Staff-entered pickup point (DR-029) -- feeds the assignment
  // recommendation engine's "distance from pickup" factor. Optional: most
  // departures won't have this set initially, and the engine degrades
  // gracefully (skips that factor) when it's missing.
  pickupLatitude     Float?
  pickupLongitude    Float?
  status             DepartureStatus @default(SCHEDULED)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tourPackage  TourPackage? @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  assignments  Assignment[]

  @@index([organizationId])
  @@index([tourPackageId])
  @@map("departures")
}

// ---------------------------------------------------------- assignment (DR-018, Phase 2 Increment 2)
// Links a Departure to the vehicle/driver/guide staffing it. A departure can
// have several Assignment rows (one per vehicle) once its capacity exceeds a
// single vehicle's seatCapacity -- @@unique below just stops the same
// vehicle being double-entered for the same departure, not a 1:1 cap.
model Assignment {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  departureId     String   @db.Uuid
  vehicleId       String   @db.Uuid
  driverProfileId String   @db.Uuid
  guideUserId     String?  @db.Uuid // TOUR_GUIDE-role user; optional
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departure     Departure     @relation(fields: [departureId], references: [id], onDelete: Cascade)
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  guide         User?         @relation(fields: [guideUserId], references: [id])

  @@unique([departureId, vehicleId])
  @@index([organizationId])
  @@index([departureId])
  @@index([vehicleId])
  @@index([driverProfileId])
  @@map("assignments")
}

// A tourist's seat reservation on a Departure (PREDEFINED_PACKAGE), or a
// bespoke trip request with no fixed Departure (TAILOR_MADE, priced by staff
// via a quotation). A "hold" is not a separate entity — it's this same row
// with status=AWAITING_DEPOSIT and holdExpiresAt set; DB lazy expiry means
// any read that cares about current capacity treats an expired, not-yet-
// flipped AWAITING_DEPOSIT row as not occupying a seat (see booking module).
// A TAILOR_MADE booking has no departure/capacity to protect, so it never
// gets a holdExpiresAt even while AWAITING_DEPOSIT.
// Status alone encodes the ordinary lifecycle (cancellation/refund do NOT
// set deletedAt -- a cancelled booking's history still needs to survive for
// audit/reconciliation). deletedAt (DR-058) is a separate, explicit,
// SUPERADMIN-only "delete this booking" action, staff-triggered, never
// automatic -- it hides the row from every read path in this module
// immediately, then the row (and everything cascading off it) is
// permanently purged BOOKING_DELETION_RETENTION_DAYS days later by the
// same lazy sweepLifecycle convention this module already uses for
// hold-expiry/status transitions.
model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @db.Uuid
  origin             BookingOrigin @default(PREDEFINED_PACKAGE)
  // Null only for a TAILOR_MADE booking -- no fixed departure exists yet.
  departureId        String?       @db.Uuid
  touristUserId      String        @db.Uuid
  seats              Int
  status             BookingStatus @default(DRAFT)
  holdExpiresAt      DateTime? // set only while status = AWAITING_DEPOSIT, and only for a PREDEFINED_PACKAGE booking
  // Seats * effective unit price for PREDEFINED_PACKAGE, snapshotted at hold
  // time. Null for TAILOR_MADE until staff sends a quotation (sendQuotation).
  priceMinor         Int?
  currency           Currency?
  // Set when the add-ons wizard step is submitted, even choosing none --
  // gates invoice creation so the invoice's subtotal always reflects the
  // final add-on selection (see bookingService.getBillableTotal).
  addonsFinalizedAt  DateTime?
  // Snapshotted when add-ons are finalized (setAddons): true only if the
  // selection included the VISA_ASSISTANCE add-on. Drives whether the
  // Passport wizard step appears at all, and for how many travelers --
  // computed once here rather than re-joining BookingAddon -> AddonService
  // on every page render (see domain.isTravelerManifestComplete).
  requiresPassportUpload Boolean   @default(false)
  // Business-facing reference, e.g. shown on invoices/receipts and used as
  // the sole "find my booking" lookup key (+ the tour lead's last name --
  // see bookingService.lookupByBookingReference). DR-052 removed the
  // separate confirmationCode secret this coexisted with -- bookingReference
  // was already shown non-privately everywhere, so keeping both was
  // confusing without adding real protection. Pattern (DR-045): 6 chars,
  // 2-3 non-adjacent unique uppercase letters + unique digits -- see
  // src/modules/booking/domain.ts's generateBookingReference;
  // booking_reference_seq is dead (superseded by that same DR-045 change).
  bookingReference   String        @unique
  specialRequests    String?       @db.VarChar(1000)
  // TAILOR_MADE-only fields (all null/empty for a PREDEFINED_PACKAGE booking).
  customCountry      String?       @db.VarChar(2) // ISO-3166 alpha-2; drives tax-rate lookup in lieu of a Departure's package
  customTravelStart  DateTime?
  customTravelEnd    DateTime?
  customDescription  String?       @db.VarChar(2000)
  // Guest preference context for staff pricing a bespoke request (DR-046) --
  // NOT a matching/scoring input (the old quiz's package-ranking role is
  // gone entirely). Same PackageTag enum TourPackage.tags already uses.
  preferredTags      PackageTag[]  @default([])
  preferredSites     String[]      @default([])
  // DR-047: the full set of countries a guest ticked on /plan-my-trip
  // (customCountry above is just the first pick -- still the sole driver
  // of tax/visa lookups, unchanged). Contact email is booking-scoped, not
  // written onto User.email (which is better-auth-managed and @unique --
  // two different guests submitting the same real email would collide).
  preferredCountries String[]      @default([])
  contactEmail       String?       @db.VarChar(320)
  // DR-057: the guest's own name at inquiry time, booking-scoped like
  // contactEmail above -- needed because /find-booking's last-name check
  // otherwise has nothing to match against for a TAILOR_MADE booking still
  // AWAITING_QUOTATION/QUOTATION_SENT (no Traveler/tour-lead row exists
  // until the setup wizard runs, which only starts after a quotation is
  // accepted). Not written onto User.name, which the wizard's contact step
  // already sets separately for account-profile purposes.
  contactFirstName   String?       @db.VarChar(100)
  contactLastName    String?       @db.VarChar(100)
  // DR-048: guest-expressed add-on interest (same AddonCode enum
  // BookingAddon/AddonService use for a real priced predefined-package
  // add-on) -- staff context only here, no priced AddonService/BookingAddon
  // row exists yet for a bespoke inquiry with no package to attach one to.
  preferredAddons    AddonCode[]   @default([])
  // ISO-3166 alpha-2 -- same convention as Traveler.nationality, but this
  // is the *guest's* own residence/citizenship (relevant to visa-assistance
  // interest), collected at inquiry time rather than per-traveler later.
  countryOfResidence String?       @db.VarChar(2)
  citizenship        String?       @db.VarChar(2)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  // DR-058: see this model's own doc comment above -- a deliberate,
  // explicit, SUPERADMIN-only delete action, not an automatic side effect
  // of cancellation/refund.
  deletedAt          DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departure    Departure?     @relation(fields: [departureId], references: [id], onDelete: Cascade)
  tourist      User           @relation(fields: [touristUserId], references: [id], onDelete: Cascade)
  invoice      Invoice?
  travelers    Traveler[]
  addons       BookingAddon[]
  itinerary    Itinerary?
  ratingCode   RatingCode?
  review       Review?

  @@index([organizationId])
  @@index([departureId])
  @@index([touristUserId])
  @@index([status, holdExpiresAt]) // cheap index scan for the expiry sweep
  @@index([deletedAt]) // cheap index scan for the retention-purge sweep
  @@map("bookings")
}

// One row per seat on a Booking -- captures who is actually traveling.
// Exactly one Traveler per Booking has isTourLead = true (a solo booking's
// one traveler is trivially its own tour lead); only that traveler needs a
// passport upload (see Document).
model Traveler {
  id                       String   @id @default(uuid()) @db.Uuid
  organizationId           String   @db.Uuid
  bookingId                String   @db.Uuid
  firstName                String
  lastName                 String
  age                      Int
  sex                      Sex
  nationality              String // ISO-3166 alpha-2, matches TourPackage.country
  idOrPassportNumber       String
  phone                    String? // E.164 -- only ever collected for the tour lead
  // ISO-3166 alpha-2, same convention as nationality -- only ever collected
  // for the tour lead (the wizard's point of contact for the whole party).
  countryOfResidence       String?
  // Only ever collected for the tour lead -- distinct from Booking
  // .contactEmail (TAILOR_MADE-only, DR-047), since a PREDEFINED_PACKAGE
  // booking has no booking-level contact field of its own.
  email                    String?
  disabilities             String?
  allergies                String?
  drinkPreference          String?
  // Guides Module (DR-030) -- a guide's dashboard needs this for their
  // assigned travelers; nothing captured it before.
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  isTourLead               Boolean  @default(false)
  passportDocumentId       String?  @unique @db.Uuid
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking          Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passportDocument Document?        @relation(fields: [passportDocumentId], references: [id])
  visaApplication  VisaApplication?

  @@index([organizationId])
  @@index([bookingId])
  @@map("travelers")
}

// ------------------------------------------------------------- visa (DR-019, Phase 2 Increment 3)
enum VisaStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

// A per-traveler visa workflow, staged SUBMITTED -> APPROVED/REJECTED, with a
// REJECTED application resubmittable back to SUBMITTED (DR-025). Traveler
// identity fields are snapshotted here (not joined live) -- originally so
// IMMIGRATION_OFFICER's country-scoped list never needed booking.read; that
// role was removed in DR-032, but the snapshot stays since
// VISA_FACILITATOR's own queue (DR-031) also benefits from it.
model VisaApplication {
  id                         String     @id @default(uuid()) @db.Uuid
  organizationId             String     @db.Uuid
  travelerId                 String     @unique @db.Uuid
  country                    String // ISO-3166 alpha-2, destination -- snapshotted from the departure's package at submit time
  travelerFirstName          String
  travelerLastName           String
  travelerNationality        String
  travelerIdOrPassportNumber String
  status                     VisaStatus @default(SUBMITTED)
  rejectionReason            String?    @db.VarChar(500) // set when status becomes REJECTED; cleared on resubmit and on a later APPROVED decision -- durable history of a past rejection lives in audit_logs, not here (DR-025)
  resubmissionCount          Int        @default(0) // display-only counter, bumped by repository.resubmit -- not itself a business rule
  documentId                 String?    @unique @db.Uuid // the granted visa doc
  submittedAt                DateTime   @default(now())
  decidedAt                  DateTime?
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  traveler     Traveler     @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  document     Document?    @relation(fields: [documentId], references: [id])

  @@index([organizationId])
  @@index([country])
  @@map("visa_applications")
}

// Generic document reference -- object storage holds the bytes, this table
// holds only metadata (Documents rule, CLAUDE.md). Reusable by Phase 2 visa
// documents later; `kind` is a plain string (not an enum) so that doesn't
// need a migration. blobPathname is never sent to the client -- downloads go
// through an authenticated route that streams the bytes server-side.
// `expiresAt`/`vehicleId`/`driverProfileId` added in DR-017 (Phase 2
// Increment 1) for compliance documents (vehicle registration/insurance/
// inspection, driver license) -- unused by PASSPORT rows. A vehicle/driver
// can have several compliance documents with different expiries, so the FK
// lives on this (many) side, the mirror image of Traveler.passportDocumentId
// (a 1:1, FK on the "one" side) -- both are the natural Prisma shape for
// their own multiplicity, not an inconsistency.
model Document {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @db.Uuid
  kind             String // "PASSPORT" | "VEHICLE_REGISTRATION" | "VEHICLE_INSURANCE" | "VEHICLE_INSPECTION" | "DRIVER_LICENSE" | "VISA"
  blobPathname     String // Vercel Blob pathname, access: 'private' -- never sent to the client
  contentType      String
  sizeBytes        Int
  uploadedByUserId String    @db.Uuid
  expiresAt        DateTime? // compliance documents only
  vehicleId        String?   @db.Uuid
  driverProfileId  String?   @db.Uuid
  guideProfileId   String?   @db.Uuid // GUIDE_CERTIFICATION docs (DR-030)
  createdAt        DateTime  @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  traveler        Traveler?
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverProfile   DriverProfile?   @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  guideProfile    GuideProfile?    @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  visaApplication VisaApplication?

  @@index([organizationId])
  @@index([vehicleId])
  @@index([driverProfileId])
  @@index([guideProfileId])
  @@map("documents")
}

// ------------------------------------------------------------- fleet (DR-017, Phase 2 Increment 1)
// Foundational data for Phase 2 (fleet + compliance, DR-017); linked to
// Departure via Assignment starting DR-018. GPS v1 (later increment) will
// attach here too.
model Vehicle {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  ownerId        String?       @db.Uuid // VEHICLE_OWNER user; null = operator-owned
  plateNumber    String
  vin            String? // chassis/VIN (DR-029) -- distinct from plateNumber, not every jurisdiction requires it up front
  make           String
  model          String
  year           Int?
  vehicleType    String // open-ended (sedan/minibus/4x4/boat...) -- varies too much across NA/DRC for an enum
  seatCapacity   Int
  status         VehicleStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner              User?               @relation(fields: [ownerId], references: [id])
  documents          Document[]
  assignments        Assignment[]
  maintenanceRecords MaintenanceRecord[]
  starlinkKit        StarlinkKit?

  @@index([organizationId])
  @@index([ownerId])
  @@map("vehicles")
}

// 1:1 with a DRIVER-role User -- compliance data doesn't belong on the
// auth-owned User model (module-boundary rule, CLAUDE.md). deletedAt
// (DR-059) is a deliberate, explicit, SUPERADMIN-only "delete this driver"
// action -- distinct from `status`, which is the ordinary
// ACTIVE/SUSPENDED deactivation toggle every staff fleet.write caller uses.
model DriverProfile {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  userId           String       @unique @db.Uuid
  licenseNumber    String
  licenseExpiresAt DateTime?
  // ISO-639-1 codes, e.g. ["en","fr"] (DR-029).
  languages        String[]     @default([])
  status           DriverStatus @default(ACTIVE)
  // Live-recomputed from ReviewSubjectRating on every new Review (DR-037) --
  // null until the first rating, never incremented. Feeds
  // assignmentService.recommendAssignment's ordering.
  averageRating    Float?
  ratingCount      Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents     Document[]
  assignments   Assignment[]
  reviewRatings ReviewSubjectRating[]

  @@index([organizationId])
  @@map("driver_profiles")
}

// Guides Module (DR-030). 1:1 with a TOUR_GUIDE-role User, same module-
// boundary reasoning as DriverProfile. Note: Assignment.guideUserId still
// points directly at User (unchanged, pre-existing FK) rather than at this
// table's id -- this profile is a satellite of compliance/skill data looked
// up by userId, not the join target for assignments. "Availability" is not
// a stored field -- computed from existing Assignment overlap data.
model GuideProfile {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  userId         String      @unique @db.Uuid
  // ISO-639-1 codes, e.g. ["en","fr"], same convention as DriverProfile.
  languages      String[]    @default([])
  // Freeform (e.g. "wildlife", "gorilla trekking", "cultural") -- no fixed
  // taxonomy specified, kept consistent with languages' flexible-array shape
  // rather than inventing an unrequested enum.
  specialties    String[]    @default([])
  status         GuideStatus @default(ACTIVE)
  // Live-recomputed from ReviewSubjectRating on every new Review (DR-037) --
  // null until the first rating, never incremented. Written by userId (see
  // fleetService.recordGuideRatingAggregateByUserId), since
  // ReviewSubjectRating.guideUserId points at User, not this table's id.
  averageRating  Float?
  ratingCount    Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  // DR-059: same deliberate, explicit, SUPERADMIN-only delete action as
  // DriverProfile.deletedAt -- see that field's own comment.
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@index([organizationId])
  @@map("guide_profiles")
}

// ---------------------------------------------------------- fleet: maintenance history (DR-029)
// A simple append-only log per vehicle -- no scheduled/due-date concept yet
// (that would need a maintenance-interval policy this spec doesn't define),
// just a record of what was done and when. Feeds the assignment
// recommendation engine's "maintenance status" factor (recency as a proxy
// for risk) alongside the existing VehicleStatus.MAINTENANCE hard gate.
model MaintenanceRecord {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  vehicleId      String    @db.Uuid
  performedAt    DateTime
  description    String
  costMinor      Int? // integer minor units (BR-02), paired with currency below -- never a bare number
  currency       Currency?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vehicleId])
  @@map("maintenance_records")
}

enum StarlinkStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// A Starlink kit is a fleet resource in its own right (DR-029), 1:1 with the
// Vehicle it's currently mounted in (nullable -- a kit can be unassigned,
// e.g. newly received or being serviced). lastLatitude/lastLongitude/
// lastLocationAt are staff-entered for now, not a live feed -- there is no
// real Starlink API integration yet (no credentials, not in the approved
// stack table), matching how Resend/WhatsApp/Africa's Talking each started
// as a stub before real credentials existed (OI-05/06/07). Real live
// tracking is a future open item, not modeled here.
model StarlinkKit {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  kitId          String         @unique // Starlink's own serial/kit identifier, staff-entered
  status         StarlinkStatus @default(ACTIVE)
  vehicleId      String?        @unique @db.Uuid
  lastLatitude   Float?
  lastLongitude  Float?
  lastLocationAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])

  @@index([organizationId])
  @@map("starlink_kits")
}

// ------------------------------------------------------- itinerary (DR-033)
// Every itinerary is 1:1 with a Booking -- "the operational plan for the
// entire tour" per the spec. Deliberately does NOT duplicate
// vehicle/driver/guide assignment data (already owned by the assignment
// module, keyed by Departure, and shared across every booking on a
// PREDEFINED_PACKAGE departure) -- itineraryService reads that through
// assignmentService/fleetService's public interfaces instead. Hotels/
// restaurants are lightweight reusable reference entities (name + contact
// info only, no compliance tracking like the fleet module has), assigned
// via join tables since a trip can use several of each.
enum ItineraryStatus {
  DRAFT
  IN_REVIEW
  APPROVED
}

model Itinerary {
  id                       String          @id @default(uuid()) @db.Uuid
  organizationId           String          @db.Uuid
  bookingId                String          @unique @db.Uuid
  status                   ItineraryStatus @default(DRAFT)
  notes                    String?         @db.Text
  // Trip-level (not per-traveler -- see Traveler.emergencyContactName et al,
  // DR-030, for that) -- e.g. a local ranger station or tour-company
  // emergency line relevant to the whole group.
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  approvedAt               DateTime?
  approvedByUserId         String?         @db.Uuid
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  days         ItineraryDay[]
  hotels       ItineraryHotel[]
  restaurants  ItineraryRestaurant[]

  @@index([organizationId])
  @@map("itineraries")
}

// One row per calendar day of the trip -- "daily schedule"/"activities for
// each day"/"planned tourist sites... per day" all live here, distinct from
// Itinerary's trip-level fields. departureTime/arrivalTime are plain
// "HH:MM" strings (no existing time-of-day type in this schema, and
// timezone precision isn't needed for a same-day local activity time).
model ItineraryDay {
  id                     String   @id @default(uuid()) @db.Uuid
  organizationId         String   @db.Uuid
  itineraryId            String   @db.Uuid
  dayNumber              Int
  date                   DateTime
  departureTime          String?
  arrivalTime            String?
  pickupLocation         String?
  dropoffLocation        String?
  plannedSites           String?  @db.Text
  activities             String?  @db.Text
  estimatedTravelMinutes Int?
  notes                  String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itinerary    Itinerary    @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, dayNumber])
  @@index([organizationId])
  @@index([itineraryId])
  @@map("itinerary_days")
}

model Hotel {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  country        String    @db.VarChar(2)
  address        String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  // Staff-only 5-star rating (not a tourist-facing concept) -- live-
  // recomputed on every HotelRating submission, same pattern as
  // DriverProfile/GuideProfile/Organization's own averageRating/ratingCount.
  averageRating  Float?
  ratingCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itineraries  ItineraryHotel[]
  ratings      HotelRating[]

  @@index([organizationId])
  @@map("hotels")
}

model Restaurant {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  country        String    @db.VarChar(2)
  address        String?
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  // Staff-only 5-star rating -- same precedent as Hotel.averageRating above.
  averageRating  Float?
  ratingCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itineraries  ItineraryRestaurant[]
  ratings      RestaurantRating[]

  @@index([organizationId])
  @@map("restaurants")
}

// Staff-only hotel rating (distinct from the tourist-facing ratings module's
// DRIVER/GUIDE reviews) -- one row per (hotel, staff rater), overwritten on
// each revisit rather than accumulating a new row per visit, per explicit
// user choice. TOUR_GUIDE/DRIVER are scoped in itinerary/service.ts to only
// rate a hotel actually assigned to one of their own toured itineraries;
// TOUR_OPERATOR/PLATFORM_ADMIN (unscoped itinerary managers) can rate any.
model HotelRating {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  hotelId        String   @db.Uuid
  raterUserId    String   @db.Uuid
  rating         Int
  comment        String?  @db.VarChar(1000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hotel        Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rater        User         @relation(fields: [raterUserId], references: [id], onDelete: Cascade)

  @@unique([hotelId, raterUserId])
  @@index([organizationId])
  @@index([hotelId])
  @@map("hotel_ratings")
}

// Restaurant counterpart to HotelRating -- identical shape/rules.
model RestaurantRating {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  restaurantId   String   @db.Uuid
  raterUserId    String   @db.Uuid
  rating         Int
  comment        String?  @db.VarChar(1000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  rater        User         @relation(fields: [raterUserId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, raterUserId])
  @@index([organizationId])
  @@index([restaurantId])
  @@map("restaurant_ratings")
}

model ItineraryHotel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  itineraryId    String   @db.Uuid
  hotelId        String   @db.Uuid
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itinerary    Itinerary    @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  hotel        Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, hotelId])
  @@index([organizationId])
  @@index([hotelId])
  @@map("itinerary_hotels")
}

model ItineraryRestaurant {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  itineraryId    String   @db.Uuid
  restaurantId   String   @db.Uuid
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itinerary    Itinerary    @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, restaurantId])
  @@index([organizationId])
  @@index([restaurantId])
  @@map("itinerary_restaurants")
}

// Org-scoped catalog of priced add-on services (photography, video,
// translator, visa assistance) -- same family as TourPackage.
model AddonService {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  code           AddonCode
  name           String
  description    String
  priceMinor     Int
  currency       Currency
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingAddons BookingAddon[]

  @@index([organizationId])
  @@map("addon_services")
}

// A selected add-on on a Booking. priceMinor/currency are snapshotted at
// selection time (same pattern as Booking.priceMinor) so a later catalog
// price change never mutates an already-selected add-on.
model BookingAddon {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  bookingId      String   @db.Uuid
  addonServiceId String   @db.Uuid
  priceMinor     Int
  currency       Currency
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addonService AddonService @relation(fields: [addonServiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([bookingId])
  @@map("booking_addons")
}

// A 1:1 financial record for a Booking, created lazily on first access
// (invoicing/service.ts:getOrCreateInvoiceForBooking), not at hold time --
// tax jurisdiction + effective rate are snapshotted here so a later TaxRate
// change never mutates an already-issued invoice. DPO payments are stubbed
// this increment (OI-01 commercial terms still open) -- see Payment/gateway.ts.
model Invoice {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @db.Uuid
  bookingId         String        @unique @db.Uuid
  currency          Currency
  subtotalMinor     Int // = Booking.priceMinor at invoice-creation time
  taxRateBp         Int // snapshotted TaxRate.rateBp (BR-01/DR-006)
  taxMinor          Int
  totalMinor        Int // subtotalMinor + taxMinor
  depositMinor      Int // 40% of totalMinor, half-up (DR-012)
  balanceMinor      Int // totalMinor - depositMinor (never independently rounded -- avoids drift)
  // Settings module (DR-042): the platform's commission, computed as an
  // informational split of totalMinor -- NEVER added to it. depositMinor/
  // balanceMinor/totalMinor are the customer's real amounts, unaffected by
  // this. Nullable: existing (pre-DR-042) invoices predate the feature and
  // are grandfathered, same precedent as TourPackage.priceMinor (DR-039).
  platformFeeMinor  Int?
  platformFeeRateBp Int? // snapshotted PlatformRate.rateBp at invoice-creation time
  status            InvoiceStatus @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([organizationId])
  @@map("invoices")
}

// A single payment attempt against an Invoice (deposit or balance leg). The
// DPO gateway is stubbed this increment: initiate() fabricates a PENDING
// record + fake redirect; a staff-only "resolve" route flips it to
// SUCCEEDED/FAILED, standing in for DPO's future webhook. See
// PaymentGateway (invoicing/gateway.ts) -- only the adapter changes when
// real DPO commercial terms land, no caller does.
model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  invoiceId      String        @db.Uuid
  kind           PaymentKind
  amountMinor    Int
  currency       Currency
  provider       String        @default("DPO")
  providerRef    String? // fake reference/redirect token from the stub gateway
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@map("payments")
}

// ---------------------------------------------------------- ratings (DR-037)
// Customer Ratings & Feedback -- closes the gap DR-029/030 deliberately left
// open ("no rating field -- deferred until a real reviews system exists").
// A client rates after their tour completes, using a single-use RatingCode
// (issued by staff once the booking's invoice is PAID) + their
// bookingReference as a two-factor, session-less lookup (same shape as
// Booking.confirmationCode + last name, DR-016).
enum RatingSubjectType {
  DRIVER
  GUIDE
}

// One per Booking (bookingId unique) -- no separate status column, state is
// derived from usedAt/expiresAt (see ratingsService.isRatingCodeUsable),
// same "lazy, derived state" precedent as Booking.holdExpiresAt.
model RatingCode {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  bookingId      String    @unique @db.Uuid
  code           String    @unique
  issuedByUserId String    @db.Uuid
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  review       Review?

  @@index([organizationId])
  @@map("rating_codes")
}

// One per Booking -- a used, single-use RatingCode implies exactly one
// Review. overallRating is the mandatory "overall agency experience" score;
// per-driver/per-guide scores live in ReviewSubjectRating.
model Review {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  bookingId      String   @unique @db.Uuid
  ratingCodeId   String   @unique @db.Uuid
  touristUserId  String   @db.Uuid
  overallRating  Int
  overallComment String?  @db.VarChar(1000)
  createdAt      DateTime @default(now())

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking        Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ratingCode     RatingCode            @relation(fields: [ratingCodeId], references: [id], onDelete: Cascade)
  subjectRatings ReviewSubjectRating[]

  @@index([organizationId])
  @@index([bookingId])
  @@map("reviews")
}

// Zero-or-more per Review -- one row per rated driver/guide (a departure can
// have several vehicles/drivers, DR-018). guideUserId points at User
// directly, mirroring Assignment.guideUserId (not GuideProfile.id).
model ReviewSubjectRating {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @db.Uuid
  reviewId        String            @db.Uuid
  subjectType     RatingSubjectType
  driverProfileId String?           @db.Uuid
  guideUserId     String?           @db.Uuid
  rating          Int
  comment         String?           @db.VarChar(1000)
  createdAt       DateTime          @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  review        Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  driverProfile DriverProfile? @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  guide         User?          @relation(fields: [guideUserId], references: [id])

  @@index([organizationId])
  @@index([reviewId])
  @@index([driverProfileId])
  @@map("review_subject_ratings")
}

// ---------------------------------------------------------- finance (DR-039)
// Cost-plus pricing engine -- replaces TourPackage.priceMinor as a plain
// staff-typed number. The six rate tables below are platform-wide config
// (no organizationId, no RLS), same precedent as TaxRate/CountryRegulation,
// effective-dated (validFrom/validTo) exactly like TaxRate -- "seasonal
// pricing" is expressed as overlapping date-ranged rows, no separate season
// concept needed. PackageCostBreakdown/PackageCostLineItem ARE org-scoped
// (they're real operational data, not shared config) and get standard RLS.

enum StaffRateRole {
  DRIVER
  GUIDE
  PHOTOGRAPHER
  VIDEOGRAPHER
}

model StaffRate {
  id             String        @id @default(uuid()) @db.Uuid
  country        String // ISO-3166 alpha-2
  role           StaffRateRole
  dailyRateMinor Int
  currency       Currency
  validFrom      DateTime      @default(now())
  validTo        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([country, role, validFrom])
  @@map("staff_rates")
}

// roomCategory is freeform (e.g. "Standard", "Deluxe", "Suite") -- mirrors
// Vehicle.vehicleType's open-ended-string precedent rather than an enum,
// since categories vary too much across properties/countries.
model HotelRate {
  id               String    @id @default(uuid()) @db.Uuid
  country          String
  roomCategory     String
  nightlyRateMinor Int
  currency         Currency
  validFrom        DateTime  @default(now())
  validTo          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([country, validFrom])
  @@map("hotel_rates")
}

// All four figures are per-day estimates, summed then multiplied by a
// package's transportDays.
model TransportRate {
  id                        String    @id @default(uuid()) @db.Uuid
  country                   String
  fuelEstimateMinor         Int
  tollFeesMinor             Int
  parkingFeesMinor          Int
  vehicleOperatingCostMinor Int
  currency                  Currency
  validFrom                 DateTime  @default(now())
  validTo                   DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([country, validFrom])
  @@map("transport_rates")
}

// Merges "Restaurant estimates" (breakfast/lunch/dinner) and "Drinks"
// (water/soft drinks/juice/local/alcoholic) into one table -- both are
// per-person/per-unit consumable rates, just different category values.
enum FoodBeverageCategory {
  BREAKFAST
  LUNCH
  DINNER
  WATER
  SOFT_DRINK
  JUICE
  LOCAL_BEVERAGE
  ALCOHOLIC
}

model FoodBeverageRate {
  id           String               @id @default(uuid()) @db.Uuid
  country      String
  category     FoodBeverageCategory
  perUnitMinor Int
  currency     Currency
  validFrom    DateTime             @default(now())
  validTo      DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([country, category, validFrom])
  @@map("food_beverage_rates")
}

// Open-ended per the spec's "other attraction fees" -- name is freeform,
// same reasoning as HotelRate.roomCategory.
model ActivityFee {
  id        String    @id @default(uuid()) @db.Uuid
  country   String
  name      String
  feeMinor  Int
  currency  Currency
  validFrom DateTime  @default(now())
  validTo   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([country, validFrom])
  @@map("activity_fees")
}

// Deliberately its own table, NOT extending CountryRegulation (immigration
// module's own table, which already has an unrelated flat
// immigrationFeeMinor used for guest-facing info display) -- keeps module
// boundaries clean; finance owns its own pricing-specific fee data.
model ImmigrationCostRate {
  id                       String    @id @default(uuid()) @db.Uuid
  country                  String
  visaFeeMinor             Int
  processingFeeMinor       Int
  invitationLetterFeeMinor Int
  borderPermitFeeMinor     Int
  currency                 Currency
  validFrom                DateTime  @default(now())
  validTo                  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([country, validFrom])
  @@map("immigration_cost_rates")
}

// One per TourPackage. referenceGroupSize is the divisor for the per-seat
// price -- deliberately decoupled from any specific Departure.capacity,
// since a package can have several departures with different capacities
// but price stays package-level. Rate FKs are nullable (a package might
// have no accommodation, no visa requirement, etc.).
model PackageCostBreakdown {
  id                        String    @id @default(uuid()) @db.Uuid
  organizationId            String    @db.Uuid
  tourPackageId             String    @unique @db.Uuid
  currency                  Currency // must match TourPackage.currency -- no FX conversion anywhere in this app
  referenceGroupSize        Int
  nights                    Int
  driverDays                Int
  guideDays                 Int
  // Base-inclusion only (e.g. a premium package that bundles a
  // photographer) -- distinct from the existing per-booking optional
  // AddonService PHOTOGRAPHY/VIDEOGRAPHY purchase (DR-011/015), which stays
  // unchanged and is added on top at booking time, not here.
  photographerDays          Int       @default(0)
  videographerDays          Int       @default(0)
  hotelRateId               String?   @db.Uuid
  roomsNeeded               Int       @default(1)
  breakfastCount            Int       @default(0)
  lunchCount                Int       @default(0)
  dinnerCount               Int       @default(0)
  transportRateId           String?   @db.Uuid
  transportDays             Int       @default(0)
  requiresVisa              Boolean   @default(false)
  immigrationCostRateId     String?   @db.Uuid
  agencyMarginBp            Int // basis points, e.g. 2000 = 20%
  computedBaseCostMinor     Int?
  computedSellingPriceMinor Int?
  // Override + audit trail (spec: "Administrators may override calculated
  // prices when necessary while maintaining an audit trail"). The audit
  // trail itself lives in the append-only audit_logs table (via audit()),
  // not duplicated here -- these columns are just "is an override
  // currently in effect," not history.
  overridePriceMinor        Int?
  overrideReason            String?   @db.VarChar(500)
  overriddenByUserId        String?   @db.Uuid
  overriddenAt              DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tourPackage  TourPackage           @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
  lineItems    PackageCostLineItem[]

  @@index([organizationId])
  @@map("package_cost_breakdowns")
}

// Zero-or-more per breakdown -- one row per selected drink/meal-beyond-base
// or activity, with a per-person quantity. Exactly one of
// foodBeverageRateId/activityFeeId is set per row (mirrors
// ReviewSubjectRating's nullable-pair precedent, DR-037).
model PackageCostLineItem {
  id                     String  @id @default(uuid()) @db.Uuid
  organizationId         String  @db.Uuid
  packageCostBreakdownId String  @db.Uuid
  foodBeverageRateId     String? @db.Uuid
  activityFeeId          String? @db.Uuid
  quantityPerPerson      Int

  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packageCostBreakdown PackageCostBreakdown @relation(fields: [packageCostBreakdownId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([packageCostBreakdownId])
  @@map("package_cost_line_items")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid // matches User.id's native type -- required for the FK to work
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}
