// POLCO TOURS — Prisma schema (Phase 0 foundation)
// Implements the Vol. 6 identity/tenancy/finance/system core plus a single
// tenant-scoped table (tour_packages) used to prove Row-Level Security.
// Full ERD grows here phase by phase; every structural change is recorded in
// docs/decisions (DR-007, living-document mandate).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Neon -pooler) at runtime
  directUrl = env("DIRECT_URL") // direct connection for migrations
}

// ----------------------------------------------------------------- enums
enum Role {
  SUPERADMIN
  PLATFORM_ADMIN
  TOUR_OPERATOR
  TOUR_GUIDE
  DRIVER
  VEHICLE_OWNER
  VISA_FACILITATOR
  IMMIGRATION_OFFICER
  TOURIST
}

enum OrgStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Currency {
  USD
  EUR
  NAD
  CDF
}

enum DepartureStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

// v2 (replaces HELD/CONFIRMED/CANCELLED/EXPIRED/QUOTE_REQUESTED). A hold is
// now AWAITING_DEPOSIT + holdExpiresAt (was HELD); an expired hold lazily
// sweeps straight to CANCELLED -- there is no dedicated EXPIRED value here,
// so the expired-vs-manually-cancelled distinction survives only in the
// audit log. DRAFT exists for spec completeness; no current flow produces a
// row that stays there (both booking origins set a real starting status
// immediately on creation).
enum BookingStatus {
  DRAFT
  AWAITING_QUOTATION
  QUOTATION_SENT
  AWAITING_DEPOSIT
  DEPOSIT_PAID
  FULLY_PAID
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum BookingOrigin {
  PREDEFINED_PACKAGE
  TAILOR_MADE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentKind {
  DEPOSIT
  BALANCE
  FULL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum Locale {
  EN
  FR
}

// ICAO 9303 passport MRZ sex convention (matches what a passport encodes).
enum Sex {
  M
  F
  X
}

enum AddonCode {
  PHOTOGRAPHY
  VIDEOGRAPHY
  TRANSLATOR
  VISA_ASSISTANCE
}

// Powers the public "tailor your trip" quiz's interest-matching (DR-016).
enum PackageTag {
  WILDLIFE
  ADVENTURE
  RELAXATION
  FAMILY
  CULTURE
  LUXURY
  BUDGET
}

// Fleet + compliance (DR-017, Phase 2 Increment 1).
enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum DriverStatus {
  ACTIVE
  SUSPENDED
}

// Guides Module (DR-030) -- folded into the fleet module per explicit user
// choice, rather than a standalone module, to reuse its existing
// compliance-document/anti-BOLA plumbing directly.
enum GuideStatus {
  ACTIVE
  SUSPENDED
}

// ------------------------------------------------------------- identity
model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  countries String[] // ISO-3166 alpha-2, e.g. ["NA","CD"]
  status    OrgStatus @default(PENDING)
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members          Membership[]
  packages         TourPackage[]
  departures       Departure[]
  bookings         Booking[]
  invoices         Invoice[]
  payments         Payment[]
  travelers        Traveler[]
  documents        Document[]
  addonServices    AddonService[]
  bookingAddons    BookingAddon[]
  vehicles           Vehicle[]
  driverProfiles     DriverProfile[]
  guideProfiles      GuideProfile[]
  assignments        Assignment[]
  visaApplications   VisaApplication[]
  maintenanceRecords MaintenanceRecord[]
  starlinkKits       StarlinkKit[]

  @@map("organizations")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  name            String?
  role            Role      @default(TOURIST)
  emailVerified   Boolean   @default(false)
  image           String? // better-auth: avatar URL
  phone           String? // E.164 -- WhatsApp/SMS addressing (DR-013)
  preferredLocale Locale    @default(EN)
  isAnonymous     Boolean?  @default(false) // better-auth `anonymous` plugin (DR-016 guest checkout)
  assignedCountry String? // ISO-3166 alpha-2; IMMIGRATION_OFFICER only, set via authService.assignOfficerCountry (DR-019)
  organizationId  String?   @db.Uuid
  mustChangePassword Boolean @default(false) // set true for admin-created accounts with a generated temp password (DR-026)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  memberships      Membership[]
  sessions         Session[]
  accounts         Account[]
  bookings         Booking[]
  ownedVehicles    Vehicle[]
  driverProfile    DriverProfile?
  guideProfile     GuideProfile?
  guideAssignments Assignment[]

  @@index([organizationId])
  @@map("users")
}

// A user's role within a specific organization (multi-tenant membership).
// DR-026: real multi-role source of truth for staff accounts created via the
// admin user-management surface -- one row per (user, org, role) a user
// holds simultaneously. User.role stays a single "primary" role used
// unchanged by tourist/guest self-signup, which never gets a Membership row.
model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  organizationId String   @db.Uuid
  role           Role
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId])
  @@map("organization_members")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// --------------------------------------------------------------- finance
// Per-country, effective-dated tax (DR-006 / BR-01). Rate in basis points.
model TaxRate {
  id        String    @id @default(uuid()) @db.Uuid
  country   String // ISO-3166 alpha-2
  taxType   String    @default("VAT")
  rateBp    Int // 1600 = 16.00%
  validFrom DateTime  @default(now())
  validTo   DateTime?

  @@index([country, taxType, validFrom])
  @@map("tax_rates")
}

// ---------------------------------------------------------------- system
// Append-only. INSERT/UPDATE/DELETE grants are locked down in rls.sql.
model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  actorUserId    String?  @db.Uuid
  actorRole      Role?
  action         String
  resourceType   String
  resourceId     String?
  organizationId String?  @db.Uuid
  ip             String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ------------------------------------------------------------ catalog (Vol. 1)
// Tenant-scoped. RLS policies in rls.sql enforce that a request only sees rows
// for the organization in the session GUC `app.org_id`.
model TourPackage {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  // Business-facing reference, e.g. PKG-00034, from a plain Postgres sequence
  // (package_reference_seq -- not representable in Prisma's schema DSL, see
  // src/modules/catalog/repository.ts), same coexists-alongside-the-id
  // pattern as Booking.bookingReference (DR-027).
  packageReference String      @unique
  title          String
  description    String
  country        String // ISO-3166 alpha-2; matches TaxRate.country for invoicing
  priceMinor     Int // per-seat unit price, integer minor units (BR-02)
  currency       Currency
  durationDays   Int?
  tags           PackageTag[] // interest-matching for the public quiz (DR-016)
  status         PackageStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // Soft delete (DR-028) -- already existed, scaffolded but unused until now;
  // reads across this module already filter deletedAt: null.
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departures   Departure[]

  @@index([organizationId])
  @@map("tour_packages")
}

// A scheduled instance of a TourPackage. Capacity lives here (not on the
// package) because two departures of the same package can run different
// group/vehicle sizes.
//
// DR-028: tourPackageId is now nullable -- a "bespoke" departure (converted
// from an approved TAILOR_MADE Booking, see bookingService.convertToItinerary)
// has no TourPackage at all. Its country/price/currency are snapshotted
// directly onto customCountry/priceOverrideMinor/currency instead (catalog
// module cannot depend on the booking module -- see catalogService
// .createBespokeDeparture -- so these carry what a package join would
// otherwise have supplied). A bespoke departure is never publicly listed and
// exists solely so the existing Assignment machinery can attach to it.
model Departure {
  id                 String          @id @default(uuid()) @db.Uuid
  organizationId     String          @db.Uuid
  tourPackageId      String?         @db.Uuid
  startDate          DateTime
  endDate            DateTime?
  capacity           Int
  priceOverrideMinor Int? // null = inherit TourPackage.priceMinor/currency; for a bespoke departure, this IS the price (no package to inherit from)
  currency           Currency? // bespoke departures only -- a package-backed departure inherits TourPackage.currency
  customCountry      String?         @db.VarChar(2) // bespoke departures only -- ISO-3166 alpha-2, snapshotted from the originating Booking
  // Staff-entered pickup point (DR-029) -- feeds the assignment
  // recommendation engine's "distance from pickup" factor. Optional: most
  // departures won't have this set initially, and the engine degrades
  // gracefully (skips that factor) when it's missing.
  pickupLatitude     Float?
  pickupLongitude    Float?
  status             DepartureStatus @default(SCHEDULED)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tourPackage  TourPackage?  @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  assignments  Assignment[]

  @@index([organizationId])
  @@index([tourPackageId])
  @@map("departures")
}

// ---------------------------------------------------------- assignment (DR-018, Phase 2 Increment 2)
// Links a Departure to the vehicle/driver/guide staffing it. A departure can
// have several Assignment rows (one per vehicle) once its capacity exceeds a
// single vehicle's seatCapacity -- @@unique below just stops the same
// vehicle being double-entered for the same departure, not a 1:1 cap.
model Assignment {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  departureId     String   @db.Uuid
  vehicleId       String   @db.Uuid
  driverProfileId String   @db.Uuid
  guideUserId     String?  @db.Uuid // TOUR_GUIDE-role user; optional
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departure     Departure     @relation(fields: [departureId], references: [id], onDelete: Cascade)
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  guide         User?         @relation(fields: [guideUserId], references: [id])

  @@unique([departureId, vehicleId])
  @@index([organizationId])
  @@index([departureId])
  @@index([vehicleId])
  @@index([driverProfileId])
  @@map("assignments")
}

// A tourist's seat reservation on a Departure (PREDEFINED_PACKAGE), or a
// bespoke trip request with no fixed Departure (TAILOR_MADE, priced by staff
// via a quotation). A "hold" is not a separate entity — it's this same row
// with status=AWAITING_DEPOSIT and holdExpiresAt set; DB lazy expiry means
// any read that cares about current capacity treats an expired, not-yet-
// flipped AWAITING_DEPOSIT row as not occupying a seat (see booking module).
// A TAILOR_MADE booking has no departure/capacity to protect, so it never
// gets a holdExpiresAt even while AWAITING_DEPOSIT.
// Deliberately no deletedAt: booking history must survive cancellation for
// audit/reconciliation — status already encodes the lifecycle.
model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  origin         BookingOrigin @default(PREDEFINED_PACKAGE)
  // Null only for a TAILOR_MADE booking -- no fixed departure exists yet.
  departureId    String?       @db.Uuid
  touristUserId  String        @db.Uuid
  seats          Int
  status         BookingStatus @default(DRAFT)
  holdExpiresAt  DateTime? // set only while status = AWAITING_DEPOSIT, and only for a PREDEFINED_PACKAGE booking
  // Seats * effective unit price for PREDEFINED_PACKAGE, snapshotted at hold
  // time. Null for TAILOR_MADE until staff sends a quotation (sendQuotation).
  priceMinor     Int?
  currency       Currency?
  // Set when the add-ons wizard step is submitted, even choosing none --
  // gates invoice creation so the invoice's subtotal always reflects the
  // final add-on selection (see bookingService.getBillableTotal).
  addonsFinalizedAt DateTime?
  // Short, human-typeable lookup code (DR-016) -- generated for every
  // booking (staff or guest) at creation time, but only ever revealed to a
  // guest once setup + payment-initiation are complete. Not a security
  // boundary on its own -- the "find my booking" flow also requires the
  // tour lead's last name (see bookingService.lookupByConfirmationCode).
  confirmationCode String @unique
  // Business-facing reference, e.g. POL-2026-000154 -- coexists with
  // confirmationCode (which stays the non-guessable guest-lookup secret).
  // Numeric part comes from a plain Postgres sequence (booking_reference_seq,
  // created out-of-band since Prisma's schema DSL can't express a custom
  // formatted default -- see src/modules/booking/repository.ts), formatted
  // in application code.
  bookingReference String @unique
  specialRequests  String? @db.VarChar(1000)
  // TAILOR_MADE-only fields (all null for a PREDEFINED_PACKAGE booking).
  customCountry     String?   @db.VarChar(2) // ISO-3166 alpha-2; drives tax-rate lookup in lieu of a Departure's package
  customTravelStart DateTime?
  customTravelEnd   DateTime?
  customDescription String?   @db.VarChar(2000)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departure    Departure?     @relation(fields: [departureId], references: [id], onDelete: Cascade)
  tourist      User           @relation(fields: [touristUserId], references: [id], onDelete: Cascade)
  invoice      Invoice?
  travelers    Traveler[]
  addons       BookingAddon[]

  @@index([organizationId])
  @@index([departureId])
  @@index([touristUserId])
  @@index([status, holdExpiresAt]) // cheap index scan for the expiry sweep
  @@map("bookings")
}

// One row per seat on a Booking -- captures who is actually traveling.
// Exactly one Traveler per Booking has isTourLead = true (a solo booking's
// one traveler is trivially its own tour lead); only that traveler needs a
// passport upload (see Document).
model Traveler {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @db.Uuid
  bookingId          String   @db.Uuid
  firstName          String
  lastName           String
  age                Int
  sex                Sex
  nationality        String // ISO-3166 alpha-2, matches TourPackage.country
  idOrPassportNumber String
  phone              String? // E.164
  disabilities       String?
  allergies          String?
  drinkPreference    String?
  // Guides Module (DR-030) -- a guide's dashboard needs this for their
  // assigned travelers; nothing captured it before.
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  isTourLead         Boolean  @default(false)
  passportDocumentId String?  @unique @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking          Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passportDocument Document?        @relation(fields: [passportDocumentId], references: [id])
  visaApplication  VisaApplication?

  @@index([organizationId])
  @@index([bookingId])
  @@map("travelers")
}

// ------------------------------------------------------------- visa (DR-019, Phase 2 Increment 3)
enum VisaStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

// A per-traveler visa workflow, staged SUBMITTED -> APPROVED/REJECTED, with a
// REJECTED application resubmittable back to SUBMITTED (DR-025). Traveler
// identity fields are snapshotted here (not joined live) so
// IMMIGRATION_OFFICER's country-scoped list never needs booking.read --
// that role's whole footprint stays `immigration.read` only (BR-10 "strictly
// read-only, single-permission").
model VisaApplication {
  id                         String     @id @default(uuid()) @db.Uuid
  organizationId             String     @db.Uuid
  travelerId                 String     @unique @db.Uuid
  country                    String // ISO-3166 alpha-2, destination -- snapshotted from the departure's package at submit time
  travelerFirstName          String
  travelerLastName           String
  travelerNationality        String
  travelerIdOrPassportNumber String
  status                     VisaStatus @default(SUBMITTED)
  rejectionReason            String?    @db.VarChar(500) // set when status becomes REJECTED; cleared on resubmit and on a later APPROVED decision -- durable history of a past rejection lives in audit_logs, not here (DR-025)
  resubmissionCount          Int        @default(0) // display-only counter, bumped by repository.resubmit -- not itself a business rule
  documentId                 String?    @unique @db.Uuid // the granted visa doc
  submittedAt                DateTime   @default(now())
  decidedAt                  DateTime?
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  traveler     Traveler     @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  document     Document?    @relation(fields: [documentId], references: [id])

  @@index([organizationId])
  @@index([country])
  @@map("visa_applications")
}

// Generic document reference -- object storage holds the bytes, this table
// holds only metadata (Documents rule, CLAUDE.md). Reusable by Phase 2 visa
// documents later; `kind` is a plain string (not an enum) so that doesn't
// need a migration. blobPathname is never sent to the client -- downloads go
// through an authenticated route that streams the bytes server-side.
// `expiresAt`/`vehicleId`/`driverProfileId` added in DR-017 (Phase 2
// Increment 1) for compliance documents (vehicle registration/insurance/
// inspection, driver license) -- unused by PASSPORT rows. A vehicle/driver
// can have several compliance documents with different expiries, so the FK
// lives on this (many) side, the mirror image of Traveler.passportDocumentId
// (a 1:1, FK on the "one" side) -- both are the natural Prisma shape for
// their own multiplicity, not an inconsistency.
model Document {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @db.Uuid
  kind             String // "PASSPORT" | "VEHICLE_REGISTRATION" | "VEHICLE_INSURANCE" | "VEHICLE_INSPECTION" | "DRIVER_LICENSE" | "VISA"
  blobPathname     String // Vercel Blob pathname, access: 'private' -- never sent to the client
  contentType      String
  sizeBytes        Int
  uploadedByUserId String    @db.Uuid
  expiresAt        DateTime? // compliance documents only
  vehicleId        String?   @db.Uuid
  driverProfileId  String?   @db.Uuid
  guideProfileId   String?   @db.Uuid // GUIDE_CERTIFICATION docs (DR-030)
  createdAt        DateTime  @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  traveler        Traveler?
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverProfile   DriverProfile?   @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  guideProfile    GuideProfile?    @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  visaApplication VisaApplication?

  @@index([organizationId])
  @@index([vehicleId])
  @@index([driverProfileId])
  @@index([guideProfileId])
  @@map("documents")
}

// ------------------------------------------------------------- fleet (DR-017, Phase 2 Increment 1)
// Foundational data for Phase 2 (fleet + compliance, DR-017); linked to
// Departure via Assignment starting DR-018. GPS v1 (later increment) will
// attach here too.
model Vehicle {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  ownerId        String?       @db.Uuid // VEHICLE_OWNER user; null = operator-owned
  plateNumber    String
  vin            String?       // chassis/VIN (DR-029) -- distinct from plateNumber, not every jurisdiction requires it up front
  make           String
  model          String
  year           Int?
  vehicleType    String // open-ended (sedan/minibus/4x4/boat...) -- varies too much across NA/DRC for an enum
  seatCapacity   Int
  status         VehicleStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner              User?               @relation(fields: [ownerId], references: [id])
  documents          Document[]
  assignments        Assignment[]
  maintenanceRecords MaintenanceRecord[]
  starlinkKit        StarlinkKit?

  @@index([organizationId])
  @@index([ownerId])
  @@map("vehicles")
}

// 1:1 with a DRIVER-role User -- compliance data doesn't belong on the
// auth-owned User model (module-boundary rule, CLAUDE.md). No deletedAt --
// deactivate via `status`, same reasoning as Booking having none.
model DriverProfile {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  userId           String       @unique @db.Uuid
  licenseNumber    String
  licenseExpiresAt DateTime?
  // ISO-639-1 codes, e.g. ["en","fr"] (DR-029). No rating field -- deferred
  // until a real reviews system exists (Phase 2 remaining item); a
  // staff-typed number with nothing backing it would be actively misleading.
  languages        String[]     @default([])
  status           DriverStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]
  assignments  Assignment[]

  @@index([organizationId])
  @@map("driver_profiles")
}

// Guides Module (DR-030). 1:1 with a TOUR_GUIDE-role User, same module-
// boundary reasoning as DriverProfile. Note: Assignment.guideUserId still
// points directly at User (unchanged, pre-existing FK) rather than at this
// table's id -- this profile is a satellite of compliance/skill data looked
// up by userId, not the join target for assignments. No rating field, same
// deferral as DriverProfile (no reviews system to back one); "availability"
// is likewise not a stored field -- computed from existing Assignment
// overlap data, same as drivers.
model GuideProfile {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  userId         String      @unique @db.Uuid
  // ISO-639-1 codes, e.g. ["en","fr"], same convention as DriverProfile.
  languages      String[]    @default([])
  // Freeform (e.g. "wildlife", "gorilla trekking", "cultural") -- no fixed
  // taxonomy specified, kept consistent with languages' flexible-array shape
  // rather than inventing an unrequested enum.
  specialties    String[]    @default([])
  status         GuideStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@index([organizationId])
  @@map("guide_profiles")
}

// ---------------------------------------------------------- fleet: maintenance history (DR-029)
// A simple append-only log per vehicle -- no scheduled/due-date concept yet
// (that would need a maintenance-interval policy this spec doesn't define),
// just a record of what was done and when. Feeds the assignment
// recommendation engine's "maintenance status" factor (recency as a proxy
// for risk) alongside the existing VehicleStatus.MAINTENANCE hard gate.
model MaintenanceRecord {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  vehicleId      String   @db.Uuid
  performedAt    DateTime
  description    String
  costMinor      Int? // integer minor units (BR-02), paired with currency below -- never a bare number
  currency       Currency?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vehicleId])
  @@map("maintenance_records")
}

enum StarlinkStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// A Starlink kit is a fleet resource in its own right (DR-029), 1:1 with the
// Vehicle it's currently mounted in (nullable -- a kit can be unassigned,
// e.g. newly received or being serviced). lastLatitude/lastLongitude/
// lastLocationAt are staff-entered for now, not a live feed -- there is no
// real Starlink API integration yet (no credentials, not in the approved
// stack table), matching how Resend/WhatsApp/Africa's Talking each started
// as a stub before real credentials existed (OI-05/06/07). Real live
// tracking is a future open item, not modeled here.
model StarlinkKit {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @db.Uuid
  kitId           String         @unique // Starlink's own serial/kit identifier, staff-entered
  status          StarlinkStatus @default(ACTIVE)
  vehicleId       String?        @unique @db.Uuid
  lastLatitude    Float?
  lastLongitude   Float?
  lastLocationAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])

  @@index([organizationId])
  @@map("starlink_kits")
}

// Org-scoped catalog of priced add-on services (photography, video,
// translator, visa assistance) -- same family as TourPackage.
model AddonService {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  code           AddonCode
  name           String
  description    String
  priceMinor     Int
  currency       Currency
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingAddons BookingAddon[]

  @@index([organizationId])
  @@map("addon_services")
}

// A selected add-on on a Booking. priceMinor/currency are snapshotted at
// selection time (same pattern as Booking.priceMinor) so a later catalog
// price change never mutates an already-selected add-on.
model BookingAddon {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  bookingId      String   @db.Uuid
  addonServiceId String   @db.Uuid
  priceMinor     Int
  currency       Currency
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addonService AddonService @relation(fields: [addonServiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([bookingId])
  @@map("booking_addons")
}

// A 1:1 financial record for a Booking, created lazily on first access
// (invoicing/service.ts:getOrCreateInvoiceForBooking), not at hold time --
// tax jurisdiction + effective rate are snapshotted here so a later TaxRate
// change never mutates an already-issued invoice. DPO payments are stubbed
// this increment (OI-01 commercial terms still open) -- see Payment/gateway.ts.
model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  bookingId      String        @unique @db.Uuid
  currency       Currency
  subtotalMinor  Int // = Booking.priceMinor at invoice-creation time
  taxRateBp      Int // snapshotted TaxRate.rateBp (BR-01/DR-006)
  taxMinor       Int
  totalMinor     Int // subtotalMinor + taxMinor
  depositMinor   Int // 40% of totalMinor, half-up (DR-012)
  balanceMinor   Int // totalMinor - depositMinor (never independently rounded -- avoids drift)
  status         InvoiceStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([organizationId])
  @@map("invoices")
}

// A single payment attempt against an Invoice (deposit or balance leg). The
// DPO gateway is stubbed this increment: initiate() fabricates a PENDING
// record + fake redirect; a staff-only "resolve" route flips it to
// SUCCEEDED/FAILED, standing in for DPO's future webhook. See
// PaymentGateway (invoicing/gateway.ts) -- only the adapter changes when
// real DPO commercial terms land, no caller does.
model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  invoiceId      String        @db.Uuid
  kind           PaymentKind
  amountMinor    Int
  currency       Currency
  provider       String        @default("DPO")
  providerRef    String? // fake reference/redirect token from the stub gateway
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@map("payments")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid // matches User.id's native type -- required for the FK to work
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}
