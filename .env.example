# --- Database (Neon) -------------------------------------------------------
# Pooled connection (PgBouncer, "-pooler" host) used at runtime on Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/polco?sslmode=require"
# Direct connection (no pooler) used for migrations / RLS apply.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/polco?sslmode=require"

# --- Auth (Better Auth) ----------------------------------------------------
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Observability (Phase 0 optional) --------------------------------------
SENTRY_DSN=""

