# --- Database (Neon) -------------------------------------------------------
# Pooled connection (PgBouncer, "-pooler" host) used at runtime on Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/polco?sslmode=require"
# Direct connection (no pooler) used for migrations / RLS apply.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/polco?sslmode=require"

# --- Auth (Better Auth) ----------------------------------------------------
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Observability (Phase 0 optional) --------------------------------------
SENTRY_DSN=""

# --- Payments (stubbed, OI-01 open) -----------------------------------------
# DPO_COMPANY_TOKEN=""
# DPO_SERVICE_TYPE=""
# DPO_ENV="sandbox"

# --- Object storage (Vercel Blob, fra1 -- DR-010, wired up for real by DR-015) -
# Passport documents only for now; never sent to the client (see documents module).
BLOB_READ_WRITE_TOKEN=""

# --- Notifications (DR-013, DR-026) -----------------------------------------
# Every channel gracefully degrades to "unavailable" when its vars are unset.
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL=""      # defaults to onboarding@resend.dev (no domain verification needed) until a real domain is verified in Resend
# WHATSAPP_CLOUD_API_TOKEN="" # OI-06 -- deliberately left unconfigured for now
# WHATSAPP_PHONE_NUMBER_ID=""
# AFRICAS_TALKING_API_KEY=""
# AFRICAS_TALKING_USERNAME=""

# --- Rate limiting (Upstash Redis, DR-066) -----------------------------------
# Real Redis-backed rate limiting for auth sign-in/sign-up and the public
# guest lookups (find-booking, rating-code) -- see src/lib/rate-limit.ts.
# Unset (OI-10, no account provisioned yet), both gracefully degrade: auth
# falls back to better-auth's own in-memory limiter, the guest lookups fall
# back to the original audit-log-backed counter (DR-016).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- Scheduled jobs (Upstash QStash, DR-067) ---------------------------------
# Real periodic booking-lifecycle sweep across every organization -- see
# src/app/api/jobs/sweep-bookings/route.ts + src/lib/qstash.ts. Unset
# (OI-11, no account provisioned yet), the route just always rejects (401)
# rather than running an unverified sweep; the pre-existing lazy
# "sweep on next read" behavior (DR-016/058) is unaffected either way.
# QSTASH_TOKEN=""                # only needed to run scripts/register-qstash-schedule.ts
# QSTASH_CURRENT_SIGNING_KEY=""
# QSTASH_NEXT_SIGNING_KEY=""
# --- Only needed by scripts/register-qstash-schedule.ts, not by the app itself:
# APP_URL=""                     # the deployed URL QStash should call, e.g. https://polco-tours.vercel.app
